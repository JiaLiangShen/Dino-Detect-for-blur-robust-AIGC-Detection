{
  "experiment_name": "progan_motion_release",
  "backbone_path": "/path/to/dinov3-backbone",
  "train_root": "/path/to/train_root",
  "output_dir": "outputs",
  "seed": 42,
  "num_workers": 4,
  "num_classes": 2,
  "image_size": 512,
  "crop_size": 448,
  "projection_dim": 512,
  "adapter_layers": 3,
  "dropout": 0.1,
  "teacher_epochs": 8,
  "student_epochs": 15,
  "teacher_batch_size": 64,
  "student_batch_size": 32,
  "teacher_lr": 0.0001,
  "student_lr": 0.00005,
  "weight_decay": 0.0001,
  "temperature": 0.07,
  "alpha_distill": 1.0,
  "alpha_cls": 1.0,
  "alpha_feature": 0.5,
  "alpha_contrastive": 0.3,
  "blur_mode": "motion",
  "blur_probability": 0.2,
  "blur_strength_range": [0.1, 0.3],
  "mixed_blur_ratio": 0.5,
  "ccmba_root": null,
  "max_samples_per_class": null,
  "amp": true,
  "log_interval": 20,
  "save_every_epoch": false
}
